<div class="customer-login py-20 px-6 md:px-10" data-section-id="{{ section.id }}" data-section-type="login">
  <div class="max-w-[500px] mx-auto">
    
    <!-- Login Form -->
    <div id="login" class="bg-white/40 backdrop-blur-xl rounded-3xl p-8 md:p-12 border border-secondary/20 shadow-2xl shadow-secondary/5 transition-all duration-500">
      <div class="text-center mb-10">
        <h1 class="font-playfair-display text-4xl font-bold text-[#1a0509] mb-4">Maison Login</h1>
        <p class="font-jost text-sm tracking-[0.2em] uppercase text-[#8B7330] italic">Enter the house of brilliance</p>
      </div>

      {%- form 'customer_login' -%}
        {%- if form.errors -%}
          <div class="bg-red-50 border border-red-200 text-red-600 px-4 py-3 rounded-lg text-sm mb-6 font-jost">
            {{ form.errors | default_errors }}
          </div>
        {%- endif -%}

        <div class="space-y-6">
          <div class="field group">
            <label for="CustomerEmail" class="block font-jost text-[10px] uppercase tracking-[0.3em] text-[#8B7330] mb-2 pl-1">Email Essence</label>
            <input
              type="email"
              name="customer[email]"
              id="CustomerEmail"
              autocomplete="email"
              autocorrect="off"
              autocapitalize="off"
              class="w-full bg-white/50 border border-secondary/20 rounded-xl px-4 py-4 font-jost text-sm focus:outline-none focus:border-secondary transition-all group-hover:bg-white"
              placeholder="votre@email.com"
              required
            >
          </div>

          <div class="field group">
            <div class="flex justify-between items-center mb-2 pl-1">
              <label for="CustomerPassword" class="block font-jost text-[10px] uppercase tracking-[0.3em] text-[#8B7330]">Secret Key</label>
              <a href="#recover" id="RecoverPassword" class="font-jost text-[9px] uppercase tracking-[0.2em] text-[#8B7330] hover:text-secondary transition-colors">Forgot key?</a>
            </div>
            <input
              type="password"
              value=""
              name="customer[password]"
              id="CustomerPassword"
              autocomplete="current-password"
              class="w-full bg-white/50 border border-secondary/20 rounded-xl px-4 py-4 font-jost text-sm focus:outline-none focus:border-secondary transition-all group-hover:bg-white"
              placeholder="••••••••"
              required
            >
          </div>

          <button class="w-full bg-[#1a0509] text-white font-jost py-5 rounded-full text-xs uppercase tracking-[0.4em] font-bold transition-all duration-300 hover:bg-secondary hover:translate-y-[-2px] shadow-lg active:translate-y-0">
            Sign In
          </button>
        </div>

        <div class="mt-10 text-center border-t border-secondary/10 pt-8">
          <p class="font-jost text-xs text-[#8B7330] mb-4 italic">First visit to House of Midas?</p>
          <a href="{{ routes.account_register_url }}" class="font-jost text-[11px] uppercase tracking-[0.3em] text-[#1a0509] font-bold hover:text-secondary transition-colors">
            Create an Account
          </a>
        </div>
      {%- endform -%}
    </div>

    <!-- Recover Password Form -->
    <div id="recover" class="hidden bg-white/40 backdrop-blur-xl rounded-3xl p-8 md:p-12 border border-secondary/20 shadow-2xl shadow-secondary/5 transition-all duration-500">
      <div class="text-center mb-10">
        <h2 class="font-playfair-display text-4xl font-bold text-[#1a0509] mb-4">Restore Access</h2>
        <p class="font-jost text-sm tracking-[0.2em] uppercase text-[#8B7330] italic">Retrieve your heritage</p>
      </div>

      {%- form 'recover_customer_password' -%}
        {% assign recover_success = form.posted_successfully? %}

        <div class="field group mb-8">
          <label for="RecoverEmail" class="block font-jost text-[10px] uppercase tracking-[0.3em] text-[#8B7330] mb-2 pl-1">Registered Email</label>
          <input
            type="email"
            value=""
            name="email"
            id="RecoverEmail"
            autocorrect="off"
            autocapitalize="off"
            autocomplete="email"
            class="w-full bg-white/50 border border-secondary/20 rounded-xl px-4 py-4 font-jost text-sm focus:outline-none focus:border-secondary transition-all"
            placeholder="votre@email.com"
            required
          >
        </div>

        <div class="space-y-4">
          <button class="w-full bg-[#1a0509] text-white font-jost py-5 rounded-full text-xs uppercase tracking-[0.4em] font-bold transition-all duration-300 hover:bg-secondary">
            Submit Recovery
          </button>
          <a href="#login" id="HideRecoverPassword" class="block text-center font-jost text-[10px] uppercase tracking-[0.2em] text-[#8B7330] hover:text-secondary py-2">
            Cancel
          </a>
        </div>
      {%- endform -%}
    </div>

    {%- if shop.checkout.guest_login -%}
      <div class="mt-8 text-center">
        <hr class="border-secondary/10 mb-8">
        <h2 class="font-playfair-display text-2xl font-bold text-[#1a0509] mb-6">Guest Access</h2>
        {%- form 'guest_login' -%}
          <button class="w-full bg-transparent border border-[#1a0509] text-[#1a0509] font-jost py-4 rounded-full text-xs uppercase tracking-[0.3em] transition-all hover:bg-[#1a0509] hover:text-[#f0cc6e]">
            Continue as Guest
          </button>
        {%- endform -%}
      </div>
    {%- endif -%}
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const loginForm = document.getElementById('login');
      const recoverForm = document.getElementById('recover');
      const recoverBtn = document.getElementById('RecoverPassword');
      const cancelBtn = document.getElementById('HideRecoverPassword');

      if (window.location.hash === '#recover') {
        loginForm.classList.add('hidden');
        recoverForm.classList.remove('hidden');
      }

      recoverBtn.addEventListener('click', (e) => {
        e.preventDefault();
        loginForm.classList.add('hidden');
        recoverForm.classList.remove('hidden');
        window.location.hash = '#recover';
      });

      cancelBtn.addEventListener('click', (e) => {
        e.preventDefault();
        recoverForm.classList.add('hidden');
        loginForm.classList.remove('hidden');
        window.location.hash = '';
      });
    });
  </script>
</div>

{% schema %}
{
  "name": "Customer Login",
  "settings": []
}
{% endschema %}
