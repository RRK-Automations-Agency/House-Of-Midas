<div class="product">
  <h1 class="product__title">{{ product.title | escape }}</h1>
  {% if product.tags contains 'custom-made' %}
    <span class="product-badge badge--custom" style="display:inline-block;background:#f3e8ff;color:#5b21b6;padding:4px 8px;border-radius:999px;font-weight:600;font-size:12px;margin-left:8px;">Custom-made to Order</span>
  {% endif %}
  <div class="product__description rte">
    {{ product.description }}
  </div>

  {% assign selected_variant = product.selected_or_first_available_variant %}
  {% assign schema_price = selected_variant.price | divided_by: 100.0 %}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Product",
      "name": {{ product.title | json }},
      "description": {{ product.description | strip_html | strip_newlines | json }},
      "url": {{ shop.url | append: product.url | json }},
      "sku": {{ selected_variant.sku | default: selected_variant.id | json }},
      "brand": {
        "@type": "Brand",
        "name": {{ shop.name | json }}
      },
      "image": [
        {% for image in product.images %}
          {{ image | image_url: width: 1200 | json }}{% unless forloop.last %},{% endunless %}
        {% endfor %}
      ],
      "offers": {
        "@type": "Offer",
        "priceCurrency": {{ cart.currency.iso_code | default: shop.currency | json }},
        "price": {{ schema_price | json }},
        "availability": {% if selected_variant.available %}"https://schema.org/InStock"{% else %}"https://schema.org/OutOfStock"{% endif %},
        "url": {{ shop.url | append: product.url | append: '?variant=' | append: selected_variant.id | json }},
        "itemCondition": "https://schema.org/NewCondition"
      }
    }
  </script>
  
  {%- comment -%} Render product media (images, videos) using Shopify's media_tag so videos will play when present {%- endcomment -%}
  {% if product.media.size > 0 %}
    <div class="product-media mt-6">
      {% for media in product.media %}
        <div class="product-media-item mb-4">
          {{ media | media_tag }}
        </div>
      {% endfor %}
    </div>
  {% endif %}
</div>

{% comment %} Product-level brand overrides. If a product has theme metafields they will override the Featured collection defaults. {% endcomment %}
{% if product %}
  {% assign p_primary = product.metafields.theme.primary_color %}
  {% assign p_secondary = product.metafields.theme.secondary_color %}
  {% assign p_text = product.metafields.theme.text_color %}

  {% if p_primary or p_secondary or p_text %}
    <style id="product-brand-vars">
      :root {
        {% if p_primary %} --brand-primary: {{ p_primary }}; {% endif %}
        {% if p_secondary %} --brand-secondary: {{ p_secondary }}; {% endif %}
        {% if p_text %} --brand-text: {{ p_text }}; {% endif %}
      }
    </style>
    <script>
      // Expose product-level brand overrides to any client JS (React app) so SPA routes can pick them up.
      window.ShopifyBrandOverrides = window.ShopifyBrandOverrides || {};
      window.ShopifyBrandOverrides.product = {
        primary: {{ p_primary | json }} ,
        secondary: {{ p_secondary | json }} ,
        text: {{ p_text | json }}
      };
    </script>
  {% endif %}
{% endif %}

{% schema %}
{
  "name": "Product",
  "tag": "section",
  "class": "section",
  "settings": []
}
{% endschema %}
