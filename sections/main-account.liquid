<div class="customer-account py-16 md:py-28 relative overflow-hidden" data-section-id="{{ section.id }}" data-section-type="account">
  <!-- Brand accents -->
  <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-secondary/10 rounded-full blur-[120px] -mr-80 -mt-80 pointer-events-none animate-pulse-slow"></div>
  <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-primary/5 rounded-full blur-[100px] -ml-40 -mb-40 pointer-events-none opacity-50"></div>

  <div class="max-w-[1400px] mx-auto px-6 md:px-10 relative z-10">
    <div class="flex flex-col md:flex-row justify-between items-end mb-16 border-b border-secondary/20 pb-10">
      <div>
        <h1 class="font-playfair-display text-5xl md:text-6xl font-bold text-[#1a0509] mb-4 leading-tight">Maison Dashboard</h1>
        <p class="font-jost text-[10px] tracking-[0.4em] uppercase text-secondary font-bold flex items-center gap-3">
          <span class="w-10 h-[1px] bg-secondary/40"></span>
          Welcome back, {{ customer.first_name | default: 'Midas Guest' }}
        </p>
      </div>
      <div class="flex items-center gap-6 mt-8 md:mt-0">
        <a href="{{ routes.account_logout_url }}" class="group relative font-jost text-[10px] uppercase tracking-[0.3em] text-[#5c0d1a] px-8 py-3.5 rounded-full overflow-hidden transition-all duration-500 hover:text-white border border-[#5c0d1a]/20">
          <div class="absolute inset-0 bg-[#5c0d1a] translate-y-full group-hover:translate-y-0 transition-transform duration-500"></div>
          <span class="relative z-10 font-bold">Sign Out</span>
        </a>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-[1fr_400px] gap-12 lg:gap-24">
      
      <!-- Orders Section -->
      <div class="orders-wrapper">
        <h2 class="font-playfair-display text-3xl font-bold text-[#1a0509] mb-12 flex items-center gap-6">
          <span class="w-12 h-[1px] bg-secondary/30"></span>
          Acquisition History
        </h2>

        {%- paginate customer.orders by 20 -%}
          {%- if customer.orders.size > 0 -%}
            <div class="space-y-8">
              {%- for order in customer.orders -%}
                <div class="order-card bg-white/40 backdrop-blur-xl rounded-[2.5rem] p-8 border border-secondary/10 hover:border-secondary/30 transition-all duration-500 group hover:shadow-[0_20px_50px_rgba(191,147,64,0.08)]">
                  <div class="flex flex-wrap justify-between items-center gap-6">
                    <div class="flex items-center gap-8">
                      <div class="w-16 h-16 bg-secondary/5 rounded-2xl flex items-center justify-center text-secondary group-hover:bg-secondary/10 transition-colors shadow-inner">
                        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                      </div>
                      <div>
                        <p class="font-jost text-[9px] uppercase tracking-[0.3em] text-secondary/50 mb-1 font-bold">Collection Ref.</p>
                        <a href="{{ order.customer_url }}" class="font-playfair-display text-2xl font-bold text-[#1a0509] hover:text-secondary transition-colors inline-block mb-1">#{{ order.name }}</a>
                        <p class="font-jost text-xs text-secondary/60">{{ order.created_at | time_tag: format: 'date' }}</p>
                      </div>
                    </div>

                    <div class="flex items-center gap-12">
                      <div class="text-center">
                        <p class="font-jost text-[9px] uppercase tracking-[0.3em] text-secondary/50 mb-3 font-bold">Status</p>
                        <span class="inline-block px-5 py-2 rounded-full text-[9px] uppercase tracking-[0.2em] font-bold shadow-sm
                          {% if order.fulfillment_status_label == 'Fulfilled' %}bg-green-50 text-green-700 border border-green-100{% else %}bg-secondary/5 text-secondary border border-secondary/10{% endif %}">
                          {{ order.fulfillment_status_label }}
                        </span>
                      </div>
                      <div class="text-right">
                        <p class="font-jost text-[9px] uppercase tracking-[0.3em] text-secondary/50 mb-2 font-bold">Investment</p>
                        <p class="font-jost text-xl font-bold text-[#1a0509] tracking-widest">{{ order.total_price | money }}</p>
                      </div>
                    </div>
                  </div>
                </div>
              {%- endfor -%}
            </div>
            
            {%- if paginate.pages > 1 -%}
              <div class="mt-16">
                {% render 'pagination', paginate: paginate %}
              </div>
            {%- endif -%}
          {%- else -%}
            <div class="text-center py-28 bg-white/20 rounded-[3rem] border-2 border-dashed border-secondary/10 backdrop-blur-sm">
              <div class="w-20 h-20 bg-secondary/5 rounded-full flex items-center justify-center mx-auto mb-8">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="text-secondary/40"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
              </div>
              <p class="font-playfair-display italic text-secondary text-2xl tracking-wide max-w-sm mx-auto mb-10">Your collection is awaiting its first masterpiece.</p>
              <a href="{{ routes.collections_url }}" class="inline-block bg-[#1a0509] text-white font-jost px-12 py-5 rounded-full text-[10px] uppercase tracking-[0.4em] font-bold transition-all duration-500 hover:bg-secondary hover:shadow-2xl hover:-translate-y-1">Begin Your Legacy</a>
            </div>
          {%- endif -%}
        {%- endpaginate -%}
      </div>

      <!-- Account Summary -->
      <aside class="account-summary pt-12 lg:pt-0">
        <div class="sticky top-36 space-y-10">
          
          <!-- Profile Card -->
          <div class="bg-gradient-to-br from-[#1a0509] to-[#2d0a10] rounded-[2.5rem] p-10 text-white shadow-2xl overflow-hidden relative group">
            <div class="absolute top-0 right-0 w-48 h-48 bg-secondary/10 rounded-full blur-3xl -mr-16 -mt-16 transition-all duration-1000 group-hover:scale-125"></div>
            <h3 class="font-playfair-display text-2xl font-bold mb-10 relative z-10 italic flex items-center gap-4">
               Portfolio Profile
               <span class="w-8 h-[1px] bg-secondary/30"></span>
            </h3>
            <div class="space-y-8 relative z-10">
              <div class="group border-b border-white/5 pb-6">
                <p class="font-jost text-[9px] uppercase tracking-[0.4em] text-white/30 mb-2 font-bold">Curated for</p>
                <p class="font-playfair-display text-xl leading-none">{{ customer.name }}</p>
              </div>
              <div class="group border-b border-white/5 pb-6">
                <p class="font-jost text-[9px] uppercase tracking-[0.4em] text-white/30 mb-2 font-bold">Email Essence</p>
                <p class="font-jost text-sm tracking-widest">{{ customer.email }}</p>
              </div>
            </div>
          </div>

          <!-- Address Link -->
          <div class="bg-white/40 backdrop-blur-xl rounded-[2.5rem] p-10 border border-secondary/15 shadow-xl shadow-secondary/5 relative overflow-hidden group">
            <div class="absolute -bottom-10 -right-10 w-40 h-40 bg-secondary/5 rounded-full blur-2xl group-hover:bg-secondary/10 transition-colors"></div>
            <h3 class="font-playfair-display text-2xl font-bold text-[#1a0509] mb-6">Gallery Address</h3>
            {%- if customer.default_address -%}
              <div class="font-jost text-sm text-secondary mb-10 leading-relaxed font-medium">
                {{ customer.default_address | format_address | replace: '<address>', '' | replace: '</address>', '' }}
              </div>
            {%- else -%}
              <p class="font-jost text-sm text-secondary/40 italic mb-10">No registry on file.</p>
            {%- endif -%}
            <a href="{{ routes.account_addresses_url }}" class="block text-center border-2 border-[#1a0509] text-[#1a0509] font-jost py-5 rounded-full text-[10px] uppercase tracking-[0.3em] font-bold transition-all duration-500 hover:bg-[#1a0509] hover:text-[#f3efea] shadow-xl active:scale-95">
              Refine Addresses ({{ customer.addresses_count }})
            </a>
          </div>
        </div>
      </aside>

    </div>
  </div>
</div>

{% schema %}
{
  "name": "Customer Account",
  "settings": []
}
{% endschema %}
