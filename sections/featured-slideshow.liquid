<section class="featured-slideshow" data-section-id="{{ section.id }}">
  <div class="featured-slideshow__viewport">
    {% if section.settings.mode == 'auto' %}
      {% assign found = 0 %}
      {% for product in collections['all'].products %}
        {% assign loc = product.metafields.custom.featured_location %}
        {% if loc == 'slideshow' or loc == 'both' %}
          <article class="featured-slideshow__slide{% if forloop.first %} is-active{% endif %}" data-slide-index="{{ forloop.index0 }}">
            {% comment %} Build front/back images from the first two renderable assets. {% endcomment %}
            {% assign first_flip_image = blank %}
            {% assign second_flip_image = blank %}

            {% if product.media and product.media.size > 0 %}
              {% for media_item in product.media %}
                {% assign candidate_image = blank %}
                {% if media_item.media_type == 'image' %}
                  {% assign candidate_image = media_item %}
                {% elsif media_item.preview_image != blank %}
                  {% assign candidate_image = media_item.preview_image %}
                {% endif %}

                {% if candidate_image != blank %}
                  {% if first_flip_image == blank %}
                    {% assign first_flip_image = candidate_image %}
                  {% elsif second_flip_image == blank and candidate_image.src != first_flip_image.src %}
                    {% assign second_flip_image = candidate_image %}
                    {% break %}
                  {% endif %}
                {% endif %}
              {% endfor %}
            {% endif %}

            {% if first_flip_image == blank and product.images and product.images.size > 0 %}
              {% assign first_flip_image = product.images.first %}
            {% endif %}

            {% if second_flip_image == blank and product.images and product.images.size > 1 %}
              {% for image_item in product.images offset: 1 %}
                {% if image_item.src != first_flip_image.src %}
                  {% assign second_flip_image = image_item %}
                  {% break %}
                {% endif %}
              {% endfor %}
            {% endif %}

            {% if second_flip_image != blank %}
              <div class="featured-flip">
                <div class="featured-flip__inner">
                  <div class="featured-flip__face featured-flip__front">
                    {{ first_flip_image | image_url: width: 2400 | image_tag: class: 'featured-flip__img', loading: 'lazy', alt: product.title }}
                    </div>
                    <div class="featured-flip__face featured-flip__back">
                    {{ second_flip_image | image_url: width: 2400 | image_tag: class: 'featured-flip__img', loading: 'lazy', alt: product.title }}
                    </div>
                </div>
              </div>
            {% else %}
              {% if first_flip_image != blank %}
                {{ first_flip_image | image_url: width: 2400 | image_tag:
                  class: 'featured-slideshow__media',
                  loading: 'lazy',
                  alt: product.title
                }}
              {% elsif product.featured_image != blank %}
                {{ product.featured_image | image_url: width: 2400 | image_tag:
                  class: 'featured-slideshow__media',
                  loading: 'lazy',
                  alt: product.title
                }}
              {% endif %}
            {% endif %}
            <div class="featured-slideshow__overlay"></div>
            <div class="featured-slideshow__content">
              <h2 class="featured-slideshow__title">{{ product.title }}</h2>
            </div>
          </article>
          {% assign found = found | plus: 1 %}
          {% if found >= 6 %}
            {% break %}
          {% endif %}
        {% endif %}
      {% endfor %}
    {% else %}
      {% if section.blocks.size > 0 %}
      {% for block in section.blocks %}
        <article class="featured-slideshow__slide{% if forloop.first %} is-active{% endif %}" data-slide-index="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
          
          {% if block.settings.product != blank %}
            {% assign slide_product = all_products[block.settings.product] %}
            {% if slide_product != nil and slide_product.featured_image != blank %}
              {{ slide_product.featured_image | image_url: width: 2400 | image_tag:
                class: 'featured-slideshow__media',
                loading: 'lazy',
                alt: slide_product.title,
                style: 'object-fit: ' | append: block.settings.object_fit | append: '; object-position: ' | append: block.settings.object_position | append: '; transform: scale(' | append: block.settings.scale | append: ');'
              }}
            {% endif %}
          {% elsif block.settings.media_type == 'video' and block.settings.video != blank %}
            <video
              class="featured-slideshow__media"
              autoplay muted playsinline loop
              poster="{{ block.settings.poster | image_url: width: 2400 }}"
              style="object-fit: {{ block.settings.object_fit }}; object-position: {{ block.settings.object_position }}; transform: scale({{ block.settings.scale | default: 1 }});"
            >
              <source src="{{ block.settings.video | file_url }}" type="video/mp4">
            </video>
          
          {% elsif block.settings.image != blank %}
            {{ block.settings.image | image_url: width: 2400 | image_tag:
              class: 'featured-slideshow__media',
              loading: 'lazy',
              alt: block.settings.title,
              style: 'object-fit: ' | append: block.settings.object_fit | append: '; object-position: ' | append: block.settings.object_position | append: '; transform: scale(' | append: block.settings.scale | append: ');'
            }}
          
          {% else %}
            <div class="featured-slideshow__placeholder">
              <strong>Add slide media</strong>
              <span>Choose an image or video in the theme editor.</span>
            </div>
          {% endif %}

          <div class="featured-slideshow__overlay"></div>

          <div class="featured-slideshow__content">
            {% if block.settings.subtitle != blank %}
              <p class="featured-slideshow__eyebrow">{{ block.settings.subtitle }}</p>
            {% endif %}
            {% if block.settings.title != blank %}
              <h2 class="featured-slideshow__title">{{ block.settings.title }}</h2>
            {% endif %}
            {% if block.settings.caption != blank %}
              <p class="featured-slideshow__caption">{{ block.settings.caption }}</p>
            {% endif %}
          </div>

        </article>
      {% endfor %}
      {% endif %}
    {% endif %}
  </div>

  {% if section.blocks.size > 1 %}
    <div class="featured-slideshow__controls">
      <button class="featured-slideshow__arrow" data-direction="prev">‹</button>
      <button class="featured-slideshow__arrow" data-direction="next">›</button>
    </div>

    <div class="featured-slideshow__dots">
      {% for block in section.blocks %}
        <button class="featured-slideshow__dot{% if forloop.first %} is-active{% endif %}" data-slide-to="{{ forloop.index0 }}"></button>
      {% endfor %}
    </div>
  {% endif %}
</section>

<style>
.featured-slideshow {
  position: relative;
  width: 100%;
  min-height: 100vh;
  overflow: hidden;
  background: #000;
}

.featured-slideshow__viewport,
.featured-slideshow__slide,
.featured-slideshow__media {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.featured-slideshow__slide {
  opacity: 0;
  transition: opacity .6s ease;
}

.featured-slideshow__slide.is-active {
  opacity: 1;
  z-index: 1;
}

.featured-slideshow__overlay {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,.4);
  z-index: 1;
}

.featured-slideshow__content {
  position: absolute;
  inset: 0;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  color: #fff;
}

.featured-slideshow__dots {
  position: absolute;
  bottom: 2rem;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: .5rem;
}

.featured-slideshow__dot {
  width: 10px;
  height: 4px;
  background: #fff;
  opacity: .5;
}

.featured-slideshow__dot.is-active {
  width: 30px;
  opacity: 1;
}

/* Flip card styles for featured slides with multiple media */
.featured-flip {
  position: absolute;
  inset: 0;
  perspective: 1400px;
}
.featured-flip__inner {
  position: absolute;
  inset: 0;
  transform-style: preserve-3d;
  transition: transform .8s cubic-bezier(.2,.9,.2,1);
}
.featured-flip:hover .featured-flip__inner,
.featured-slideshow__slide.is-active .featured-flip__inner {
  transform: rotateY(180deg);
}
.featured-flip__face {
  position: absolute;
  inset: 0;
  backface-visibility: hidden;
}
.featured-flip__back {
  transform: rotateY(180deg);
}

/* Ensure flip images fill the face and preserve backface visibility */
.featured-flip__img {
  position: absolute !important;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  -webkit-backface-visibility: hidden;
  backface-visibility: hidden;
}
.featured-flip__inner {
  transform-origin: 50% 50%;
}
</style>

<script>
(() => {
  const root = document.querySelector('[data-section-id="{{ section.id }}"]');
  if (!root) return;

  const slides = root.querySelectorAll('.featured-slideshow__slide');
  const dots = root.querySelectorAll('.featured-slideshow__dot');
  const prev = root.querySelector('[data-direction="prev"]');
  const next = root.querySelector('[data-direction="next"]');

  let index = 0;

  function show(i) {
    index = (i + slides.length) % slides.length;

    slides.forEach((s, idx) => s.classList.toggle('is-active', idx === index));
    dots.forEach((d, idx) => d.classList.toggle('is-active', idx === index));
  }

  prev?.addEventListener('click', () => show(index - 1));
  next?.addEventListener('click', () => show(index + 1));

  dots.forEach((dot, i) => dot.addEventListener('click', () => show(i)));

  {% if section.blocks.size > 1 %}
    setInterval(() => show(index + 1), {{ section.settings.autoplay_delay | times: 1000 }});
  {% endif %}
})();
</script>

{% schema %}
{
  "name": "Featured slideshow",
  "settings": [
    {
      "type": "select",
      "id": "mode",
      "label": "Display mode",
      "default": "manual",
      "options": [
        { "value": "manual", "label": "Manual (use slide blocks)" },
        { "value": "auto", "label": "Auto (use product metafield)" }
      ]
    },
    {
      "type": "range",
      "id": "autoplay_delay",
      "min": 3,
      "max": 12,
      "step": 1,
      "unit": "s",
      "label": "Autoplay delay",
      "default": 6
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        { "type": "product", "id": "product", "label": "Product (use product featured image)" },
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "video", "id": "video", "label": "Video" },
        { "type": "text", "id": "title", "label": "Title" }
      ]
    }
  ],
  "presets": [
    { "name": "Featured slideshow" }
  ]
}
{% endschema %}