<div class="search-container py-16 md:py-28 relative overflow-hidden" data-section-id="{{ section.id }}" data-section-type="search">
  <!-- Aesthetic background elements -->
  <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-secondary/5 rounded-full blur-[120px] -mr-64 -mt-64 pointer-events-none"></div>
  <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-primary/5 rounded-full blur-[100px] -ml-40 -mb-40 pointer-events-none"></div>

  <div class="max-w-[1400px] mx-auto px-6 md:px-10 relative z-10">
    <div class="flex flex-col md:flex-row justify-between items-end mb-16 border-b border-secondary/20 pb-10">
      <div class="max-w-2xl">
        <h1 class="font-playfair-display text-5xl md:text-6xl font-bold text-[#1a0509] mb-6 leading-tight">
          {% if search.performed %}
            <span class="text-secondary/60 italic font-normal text-3xl block mb-2">Discovery of</span>
            "{{ search.terms }}"
          {% else %}
            Explore the Collection
          {% endif %}
        </h1>
        <p class="font-jost text-[10px] tracking-[0.4em] uppercase text-secondary font-bold">
          {% if search.performed %}
            {{ search.results_count }} Pieces of brilliance curated for you
          {% else %}
            The pinnacle of craftsmanship awaits
          {% endif %}
        </p>
      </div>
      <form action="{{ routes.search_url }}" method="get" role="search" class="relative mt-8 md:mt-0 w-full md:w-96 group">
        <input
          type="search"
          name="q"
          value="{{ search.terms | escape }}"
          placeholder="Search for brilliance..."
          class="w-full bg-white/20 backdrop-blur-sm border-b-2 border-secondary/20 py-4 pl-4 pr-12 font-jost text-sm focus:outline-none focus:border-secondary transition-all placeholder:text-secondary/30 italic"
        >
        <button type="submit" class="absolute right-2 top-1/2 -translate-y-1/2 text-secondary group-hover:text-[#1a0509] transition-all hover:scale-110">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        </button>
      </form>
    </div>

    {% if search.performed %}
      {% if search.results_count > 0 %}
        <div class="grid grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8 md:gap-10">
          {% for item in search.results %}
            {% if item.object_type == 'product' %}
              <div class="group relative flex flex-col h-full bg-white/30 backdrop-blur-md rounded-[2.5rem] p-4 border border-secondary/10 hover:border-secondary/30 transition-all duration-700 hover:shadow-[0_20px_50px_rgba(191,147,64,0.15)] hover:-translate-y-2">
                <div class="relative aspect-[3/4] rounded-[2rem] overflow-hidden bg-[#f3efe8] mb-6 shadow-inner">
                  <a href="{{ item.url }}" class="block h-full">
                    <img src="{{ item.featured_image | image_url: width: 800 }}" 
                         alt="{{ item.title }}" 
                         width="{{ item.featured_image.width }}"
                         height="{{ item.featured_image.height }}"
                         loading="lazy"
                         class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110">
                  </a>
                  <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700 pointer-events-none"></div>
                  <div class="absolute bottom-6 left-1/2 -translate-x-1/2 translate-y-10 group-hover:translate-y-0 opacity-0 group-hover:opacity-100 transition-all duration-500">
                    <span class="bg-white/90 backdrop-blur-md text-[#1a0509] font-jost text-[9px] uppercase tracking-[0.3em] px-6 py-2 rounded-full font-bold shadow-xl">Discovery Details</span>
                  </div>
                </div>
                <div class="px-6 pb-6 mt-auto text-center">
                  <h3 class="font-playfair-display text-lg font-bold text-[#1a0509] mb-2 group-hover:text-secondary transition-colors">{{ item.title }}</h3>
                  <div class="flex items-center justify-center gap-2">
                    <span class="w-4 h-[1px] bg-secondary/30"></span>
                    <p class="font-jost text-sm text-secondary font-medium tracking-widest">{{ item.price | money }}</p>
                    <span class="w-4 h-[1px] bg-secondary/30"></span>
                  </div>
                </div>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      {% else %}
        <div class="empty-results-state text-center py-32 bg-white/30 backdrop-blur-sm rounded-3xl border border-secondary/10 border-dashed">
          <div class="w-20 h-20 bg-secondary/10 rounded-full flex items-center justify-center mx-auto mb-8">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-secondary"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
          </div>
          <h2 class="font-playfair-display text-3xl font-bold text-[#1a0509] mb-4">No treasures found</h2>
          <p class="font-jost text-secondary/70 mb-10 max-w-md mx-auto">Your desire for uniqueness remains unmatched. Try refining your search or explore our curated collections.</p>
          <div class="flex flex-wrap justify-center gap-4">
            <a href="{{ routes.collections_url }}" class="inline-block bg-[#1a0509] text-white font-jost px-10 py-5 rounded-full text-xs uppercase tracking-[0.3em] font-bold transition-all duration-300 hover:bg-secondary hover:translate-y-[-2px]">
              Browse Collections
            </a>
          </div>
        </div>
      {% endif %}
    {% else %}
      <div class="text-center py-40 bg-white/20 rounded-3xl border border-dashed border-secondary/10">
        <p class="font-playfair-display italic text-secondary/60 text-2xl">Awaiting your search terms...</p>
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Main Search",
  "settings": []
}
{% endschema %}
